{
  "info": {
    "name": "Digzio Sprint 3 API (No Payments)",
    "description": "Complete test suite for Digzio Sprint 3 workflows (Student, Provider, Institution).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. KYC Service",
      "item": [
        {
          "name": "Student: Submit KYC",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-user-id", "value": "11111111-1111-1111-1111-111111111111" },
              { "key": "x-user-role", "value": "student" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"document_type\": \"ID_CARD\",\n  \"document_number\": \"9901015000088\"\n}"
            },
            "url": {
              "raw": "{{base_url}}:3005/api/v1/kyc/submit",
              "host": ["{{base_url}}"],
              "port": "3005",
              "path": ["api", "v1", "kyc", "submit"]
            }
          }
        },
        {
          "name": "Admin: Approve KYC",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "x-user-id", "value": "33333333-3333-3333-3333-333333333333" },
              { "key": "x-user-role", "value": "admin" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\",\n  \"notes\": \"Looks good\"\n}"
            },
            "url": {
              "raw": "{{base_url}}:3005/api/v1/kyc/{{kyc_id}}/status",
              "host": ["{{base_url}}"],
              "port": "3005",
              "path": ["api", "v1", "kyc", "{{kyc_id}}", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Application Service",
      "item": [
        {
          "name": "Student: Apply for Property",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-user-id", "value": "11111111-1111-1111-1111-111111111111" },
              { "key": "x-user-role", "value": "student" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"property_id\": \"66666666-6666-6666-6666-666666666666\",\n  \"desired_move_in_date\": \"2026-05-01\",\n  \"lease_term_months\": 12\n}"
            },
            "url": {
              "raw": "{{base_url}}:3006/api/v1/applications",
              "host": ["{{base_url}}"],
              "port": "3006",
              "path": ["api", "v1", "applications"]
            }
          }
        },
        {
          "name": "Provider: Approve Application",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "x-user-id", "value": "22222222-2222-2222-2222-222222222222" },
              { "key": "x-user-role", "value": "provider" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            },
            "url": {
              "raw": "{{base_url}}:3006/api/v1/applications/88888888-8888-8888-8888-888888888888/status",
              "host": ["{{base_url}}"],
              "port": "3006",
              "path": ["api", "v1", "applications", "88888888-8888-8888-8888-888888888888", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Lease Service",
      "item": [
        {
          "name": "Provider: Generate Lease",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-user-id", "value": "22222222-2222-2222-2222-222222222222" },
              { "key": "x-user-role", "value": "provider" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"application_id\": \"88888888-8888-8888-8888-888888888888\",\n  \"start_date\": \"2026-05-01\",\n  \"end_date\": \"2027-04-30\",\n  \"rent_amount\": 5500.00,\n  \"deposit_amount\": 5500.00\n}"
            },
            "url": {
              "raw": "{{base_url}}:3007/api/v1/leases/generate",
              "host": ["{{base_url}}"],
              "port": "3007",
              "path": ["api", "v1", "leases", "generate"]
            }
          }
        },
        {
          "name": "Student: Sign Lease",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "x-user-id", "value": "11111111-1111-1111-1111-111111111111" },
              { "key": "x-user-role", "value": "student" }
            ],
            "url": {
              "raw": "{{base_url}}:3007/api/v1/leases/{{lease_id}}/sign",
              "host": ["{{base_url}}"],
              "port": "3007",
              "path": ["api", "v1", "leases", "{{lease_id}}", "sign"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Institution API",
      "item": [
        {
          "name": "Institution: Get Linked Students",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-user-id", "value": "44444444-4444-4444-4444-444444444444" },
              { "key": "x-user-role", "value": "institution" }
            ],
            "url": {
              "raw": "{{base_url}}:3008/api/v1/institutions/students",
              "host": ["{{base_url}}"],
              "port": "3008",
              "path": ["api", "v1", "institutions", "students"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost"
    },
    {
      "key": "kyc_id",
      "value": ""
    },
    {
      "key": "lease_id",
      "value": ""
    }
  ]
}
